#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
fixture_root="$(cd "${script_dir}/.." && pwd)"

if [[ "${1:-}" == "--version" ]]; then
  printf 'mock-aderyn 0.1.0\n'
  exit 0
fi

output=""

while (($#)); do
  case "$1" in
    -o|--output)
      output="$2"
      shift 2
      ;;
    --no-snippets|--skip-update-check)
      shift
      ;;
    *)
      shift
      ;;
  esac
done

if [[ -z "$output" ]]; then
  printf 'mock-aderyn expected -o <path>\n' >&2
  exit 1
fi

mkdir -p "$(dirname "$output")"
cp "${fixture_root}/testdata/aderyn-report.json" "$output"
