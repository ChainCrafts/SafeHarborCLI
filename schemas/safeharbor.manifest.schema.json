{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://safeharbor/schemas/safeharbor.manifest.schema.json",
  "title": "SafeHarbor Compiled Manifest V1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "manifestRevision": {
      "type": "integer",
      "minimum": 1
    },
    "manifestStatus": {
      "const": "final"
    },
    "protocol": {
      "$ref": "#/$defs/protocol"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "deployment": {
      "$ref": "#/$defs/deployment"
    },
    "adapters": {
      "$ref": "#/$defs/adapters"
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "roles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/role"
      }
    },
    "invariants": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/invariant"
      }
    },
    "evidence": {
      "$ref": "#/$defs/evidence"
    },
    "review": {
      "$ref": "#/$defs/review"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "required": [
    "schemaVersion",
    "manifestRevision",
    "manifestStatus",
    "protocol",
    "source",
    "deployment",
    "scope",
    "roles",
    "invariants",
    "evidence",
    "review",
    "provenance"
  ],
  "$defs": {
    "address": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$"
    },
    "selector": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{8}$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "roleId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[-_:][a-z0-9]+)*$"
    },
    "contractId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[-_:][a-z0-9]+)*$"
    },
    "specialEntrypointKind": {
      "type": "string",
      "enum": ["receive", "fallback"]
    },
    "protocol": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "repository": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "repoCommit": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{6,40}$"
        },
        "buildSystem": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "compilerVersion": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "required": [
        "name",
        "slug",
        "repository",
        "repoCommit",
        "buildSystem",
        "compilerVersion"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "root": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "primaryContracts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "artifactRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      },
      "required": ["root", "primaryContracts", "artifactRefs"]
    },
    "deploymentContract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "address": {
          "$ref": "#/$defs/address"
        },
        "abiRef": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "bytecodeDigestAlgo": {
          "const": "keccak256"
        },
        "bytecodeHash": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{64}$"
        }
      },
      "required": ["name", "address", "abiRef", "bytecodeDigestAlgo", "bytecodeHash"]
    },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "chainId": {
          "type": "integer",
          "minimum": 1
        },
        "network": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "contracts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/deploymentContract"
          }
        }
      },
      "required": ["chainId", "network", "contracts"]
    },
    "battlechainAdapter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agreementAddress": {
          "$ref": "#/$defs/address"
        },
        "lifecycleState": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "bountyPct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "recoveryAddress": {
          "$ref": "#/$defs/address"
        },
        "commitmentWindowDays": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "agreementAddress",
        "lifecycleState",
        "bountyPct",
        "recoveryAddress",
        "commitmentWindowDays"
      ]
    },
    "adapters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "battlechain": {
          "$ref": "#/$defs/battlechainAdapter"
        }
      }
    },
    "access": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["permissionless", "role_gated", "unknown"]
        },
        "requiredRoleIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/roleId"
          }
        }
      },
      "required": ["kind"],
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "role_gated"
              }
            },
            "required": ["kind"]
          },
          "then": {
            "required": ["requiredRoleIds"]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "enum": ["permissionless", "unknown"]
              }
            },
            "required": ["kind"]
          },
          "then": {
            "not": {
              "required": ["requiredRoleIds"]
            }
          }
        }
      ]
    },
    "scopeSelector": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "selector": {
          "$ref": "#/$defs/selector"
        },
        "signature": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "payable": {
          "type": "boolean"
        },
        "inScope": {
          "type": "boolean"
        },
        "access": {
          "$ref": "#/$defs/access"
        },
        "outOfScopeReason": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "required": ["selector", "signature", "payable", "inScope", "access"],
      "allOf": [
        {
          "if": {
            "properties": {
              "inScope": {
                "const": false
              }
            },
            "required": ["inScope"]
          },
          "then": {
            "required": ["outOfScopeReason"]
          }
        }
      ]
    },
    "specialEntrypoint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entrypoint": {
          "$ref": "#/$defs/specialEntrypointKind"
        },
        "payable": {
          "type": "boolean"
        },
        "inScope": {
          "type": "boolean"
        },
        "access": {
          "$ref": "#/$defs/access"
        },
        "outOfScopeReason": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "required": ["entrypoint", "payable", "inScope", "access"],
      "allOf": [
        {
          "if": {
            "properties": {
              "entrypoint": {
                "const": "receive"
              }
            },
            "required": ["entrypoint"]
          },
          "then": {
            "properties": {
              "payable": {
                "const": true
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "inScope": {
                "const": false
              }
            },
            "required": ["inScope"]
          },
          "then": {
            "required": ["outOfScopeReason"]
          }
        }
      ]
    },
    "scopeContract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/contractId"
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "address": {
          "$ref": "#/$defs/address"
        },
        "inScope": {
          "type": "boolean"
        },
        "outOfScopeReason": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "selectors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/scopeSelector"
          }
        },
        "specialEntrypoints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/specialEntrypoint"
          }
        }
      },
      "required": ["id", "name", "address", "inScope"],
      "anyOf": [
        {
          "required": ["selectors"]
        },
        {
          "required": ["specialEntrypoints"]
        }
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "inScope": {
                "const": false
              }
            },
            "required": ["inScope"]
          },
          "then": {
            "required": ["outOfScopeReason"]
          }
        }
      ]
    },
    "attackMode": {
      "type": "string",
      "enum": ["single_tx", "multi_tx", "multi_block"]
    },
    "attackFlow": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowedModes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/attackMode"
          }
        }
      },
      "required": ["allowedModes"]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contracts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/scopeContract"
          }
        },
        "attackFlow": {
          "$ref": "#/$defs/attackFlow"
        }
      },
      "required": ["contracts", "attackFlow"]
    },
    "role": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/roleId"
        },
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "holders": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/address"
          }
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "required": ["id", "holders"]
    },
    "evidenceType": {
      "type": "string",
      "enum": [
        "trace",
        "state-diff",
        "balance-delta",
        "selector-access-breach",
        "multi-tx-sequence",
        "reproduction-script"
      ]
    },
    "invariantClass": {
      "type": "string",
      "enum": ["structural", "semantic_template", "human_authored"]
    },
    "invariantKind": {
      "type": "string",
      "enum": [
        "access_control",
        "selector_scope",
        "pause_control",
        "upgrade_control",
        "fee_boundary",
        "asset_accounting",
        "solvency",
        "mint_burn_integrity",
        "role_assumption",
        "external_dependency",
        "settlement_flow",
        "time_window"
      ]
    },
    "invariantOrigin": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "$ref": "#/$defs/invariantClass"
        },
        "engine": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "detectorId": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "templateId": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "standardReference": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "author": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "reviewer": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "required": ["type"]
    },
    "invariant": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^INV-[0-9]{3,}$"
        },
        "class": {
          "$ref": "#/$defs/invariantClass"
        },
        "kind": {
          "$ref": "#/$defs/invariantKind"
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "contracts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/contractId"
          }
        },
        "selectors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/selector"
          }
        },
        "specialEntrypoints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/specialEntrypointKind"
          }
        },
        "evidenceTypes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/evidenceType"
          }
        },
        "rationale": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "origin": {
          "$ref": "#/$defs/invariantOrigin"
        },
        "derivationConfidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": [
        "id",
        "class",
        "kind",
        "severity",
        "description",
        "evidenceTypes",
        "rationale",
        "origin"
      ],
      "anyOf": [
        {
          "required": ["contracts"]
        },
        {
          "required": ["selectors"]
        },
        {
          "required": ["specialEntrypoints"]
        }
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "class": {
                "const": "structural"
              }
            },
            "required": ["class"]
          },
          "then": {
            "properties": {
              "origin": {
                "properties": {
                  "type": {
                    "const": "structural"
                  }
                }
              }
            },
            "required": ["derivationConfidence"],
            "allOf": [
              {
                "properties": {
                  "origin": {
                    "required": ["engine"]
                  }
                }
              },
              {
                "properties": {
                  "origin": {
                    "not": {
                      "anyOf": [
                        {
                          "required": ["templateId"]
                        },
                        {
                          "required": ["standardReference"]
                        },
                        {
                          "required": ["author"]
                        }
                      ]
                    }
                  }
                }
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "class": {
                "const": "semantic_template"
              }
            },
            "required": ["class"]
          },
          "then": {
            "properties": {
              "origin": {
                "properties": {
                  "type": {
                    "const": "semantic_template"
                  }
                }
              }
            },
            "required": ["derivationConfidence"],
            "allOf": [
              {
                "properties": {
                  "origin": {
                    "required": ["engine", "templateId"]
                  }
                }
              },
              {
                "properties": {
                  "origin": {
                    "not": {
                      "required": ["author"]
                    }
                  }
                }
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "class": {
                "const": "human_authored"
              }
            },
            "required": ["class"]
          },
          "then": {
            "properties": {
              "origin": {
                "properties": {
                  "type": {
                    "const": "human_authored"
                  }
                }
              }
            },
            "allOf": [
              {
                "properties": {
                  "origin": {
                    "required": ["author"]
                  }
                }
              },
              {
                "not": {
                  "required": ["derivationConfidence"]
                }
              },
              {
                "properties": {
                  "origin": {
                    "not": {
                      "anyOf": [
                        {
                          "required": ["engine"]
                        },
                        {
                          "required": ["detectorId"]
                        },
                        {
                          "required": ["templateId"]
                        },
                        {
                          "required": ["standardReference"]
                        }
                      ]
                    }
                  }
                }
              }
            ]
          }
        }
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "acceptedTypes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/evidenceType"
          }
        },
        "minimumRequired": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/evidenceType"
          }
        }
      },
      "required": ["acceptedTypes", "minimumRequired"]
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reviewedBy": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "reviewedAt": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "required": ["reviewedBy", "reviewedAt", "notes"]
    },
    "analysisEngine": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "role": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "required": ["name", "role"]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "generatedBy": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "generatedByVersion": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "analysisEngines": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/analysisEngine"
          }
        }
      },
      "required": ["generatedBy", "generatedByVersion", "analysisEngines"]
    }
  }
}
